<Window x:Class="DynamicIslandBar.CapsuleControlCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="胶囊控制中心"
        Width="1120" Height="760"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="#00000000"
        Foreground="{DynamicResource PrimaryTextBrush}"
        ShowInTaskbar="True"
        SizeChanged="ControlCenterWindow_SizeChanged">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="7"
                            CornerRadius="16"
                            GlassFrameThickness="0" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Color x:Key="PrimaryTextBrushColor">#243B58</Color>
        <Color x:Key="InactiveTextBrushColor">#36536F</Color>
        <Color x:Key="MutedTextBrushColor">#617895</Color>
        <Color x:Key="DividerBrushColor">#5AFFFFFF</Color>
        <Color x:Key="AccentBrushColor">#4D8CFF</Color>
        <Color x:Key="FeatureSearchSurfaceBrushColor">#00000000</Color>
        <Color x:Key="FeatureSearchForegroundBrushColor">#F4FAFF</Color>
        <Color x:Key="FeatureSearchMutedBrushColor">#A8C5D8EA</Color>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="{DynamicResource PrimaryTextBrushColor}" />
        <SolidColorBrush x:Key="InactiveTextBrush" Color="{DynamicResource InactiveTextBrushColor}" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="{DynamicResource MutedTextBrushColor}" />
        <SolidColorBrush x:Key="DividerBrush" Color="{DynamicResource DividerBrushColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentBrushColor}" />
        <SolidColorBrush x:Key="AccentSecondaryBrush" Color="#4CD964" />
        <SolidColorBrush x:Key="FeatureSearchSurfaceBrush" Color="{DynamicResource FeatureSearchSurfaceBrushColor}" />
        <SolidColorBrush x:Key="FeatureSearchForegroundBrush" Color="{DynamicResource FeatureSearchForegroundBrushColor}" />
        <SolidColorBrush x:Key="FeatureSearchMutedBrush" Color="{DynamicResource FeatureSearchMutedBrushColor}" />
        <LinearGradientBrush x:Key="WindowSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#14081624" Offset="0" />
            <GradientStop Color="#02000000" Offset="0.34" />
            <GradientStop Color="#101C3450" Offset="0.72" />
            <GradientStop Color="#0A0C1C2E" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="WindowOverlayBrush" Color="#00000000" />
        <SolidColorBrush x:Key="CardBrush" Color="#00FFFFFF" />
        <LinearGradientBrush x:Key="CardBorderBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#E8FFFFFF" Offset="0" />
            <GradientStop Color="#74FFFFFF" Offset="0.34" />
            <GradientStop Color="#505A9BDA" Offset="0.66" />
            <GradientStop Color="#B8D9F1FF" Offset="0.86" />
            <GradientStop Color="#F0FFFFFF" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="EnergyFillBrush" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Color="#FF526DFF" Offset="0" />
            <GradientStop Color="#FF33C7F4" Offset="0.52" />
            <GradientStop Color="#FF58D78F" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="LiquidGlassBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#E0FFFFFF" Offset="0" />
            <GradientStop Color="#7AFFFFFF" Offset="0.18" />
            <GradientStop Color="#32EDF7FF" Offset="0.58" />
            <GradientStop Color="#70CFE6FF" Offset="0.82" />
            <GradientStop Color="#D8FFFFFF" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="GlassPillBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F0FFFFFF" Offset="0" />
            <GradientStop Color="#86FFFFFF" Offset="0.36" />
            <GradientStop Color="#50E6F2FF" Offset="0.72" />
            <GradientStop Color="#D8FFFFFF" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GlassPillBorderBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFFFF" Offset="0" />
            <GradientStop Color="#A8FFFFFF" Offset="0.45" />
            <GradientStop Color="#B05B9CFF" Offset="0.78" />
            <GradientStop Color="#FFFFFFFF" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SelectedGlassSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#32FFFFFF" Offset="0" />
            <GradientStop Color="#08FFFFFF" Offset="0.46" />
            <GradientStop Color="#182F80D8" Offset="0.78" />
            <GradientStop Color="#28FFFFFF" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SelectedGlassBorderBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFFFF" Offset="0" />
            <GradientStop Color="#9AFFFFFF" Offset="0.35" />
            <GradientStop Color="#D0478FFF" Offset="0.72" />
            <GradientStop Color="#FFFFFFFF" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource LiquidGlassBrush}" />
            <Setter Property="BorderBrush" Value="#5A6E91A9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="18">
                                <Border.Effect>
                                    <DropShadowEffect Color="#557DA5" BlurRadius="16" ShadowDepth="4" Opacity="0.18" />
                                </Border.Effect>
                            </Border>
                            <Border Margin="1" CornerRadius="17" BorderBrush="#A8FFFFFF" BorderThickness="1,1,0,0" IsHitTestVisible="False" />
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Chrome" Property="Background" Value="#A8FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.34" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="WindowButtonStyle">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#58FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="NavButtonStyle">
            <Setter Property="Height" Value="58" />
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{StaticResource InactiveTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="29">
                                <Border.Effect>
                                    <DropShadowEffect Color="#4776A8" BlurRadius="17" ShadowDepth="5" Opacity="0.22" />
                                </Border.Effect>
                            </Border>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryButtonStyle">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="{StaticResource GlassPillBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource GlassPillBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="20">
                                <Border.Effect>
                                    <DropShadowEffect Color="#5279A0" BlurRadius="16" ShadowDepth="4" Opacity="0.18" />
                                </Border.Effect>
                            </Border>
                            <Border Margin="1" CornerRadius="19" BorderBrush="#B8FFFFFF" BorderThickness="1,1,0,0" />
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.86" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="ThemeCardStyle">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="22">
                                <Border.Effect>
                                    <DropShadowEffect Color="#4C7094" BlurRadius="24" ShadowDepth="7" Opacity="0.20" />
                                </Border.Effect>
                            </Border>
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource LiquidGlassBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="#72FFFFFF" />
            <Setter Property="BorderBrush" Value="#86FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style x:Key="FeatureSearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource FeatureSearchForegroundBrush}" />
            <Setter Property="Background" Value="#14FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="CaretBrush" Value="#4CD964" />
            <Setter Property="Padding" Value="16,0,46,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Chrome" CornerRadius="22" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#E034C759" />
                                <Setter TargetName="Chrome" Property="Background" Value="#24FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FeatureSearchButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="FeatureSearchResultItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Chrome" Margin="0,2" CornerRadius="16" Padding="2"
                                Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="Transparent" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="Transparent" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource SelectedGlassBorderBrush}" />
                                <Setter TargetName="Chrome" Property="BorderThickness" Value="1.25" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="#24FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press" Foreground="{TemplateBinding Foreground}"
                                          Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboChrome" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="20">
                                            <Grid>
                                                <ContentPresenter Margin="12,8" HorizontalAlignment="Left" VerticalAlignment="Center" />
                                                <Path Width="10" Height="6" Margin="0,0,14,0" Fill="{StaticResource AccentBrush}"
                                                      HorizontalAlignment="Right" VerticalAlignment="Center"
                                                      Stretch="Uniform" Data="M2,3 L10,11 L18,3 Z" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" />
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" IsOpen="{TemplateBinding IsDropDownOpen}" PopupAnimation="Fade">
                                <Border MinWidth="240" MaxHeight="260" Margin="0,7,0,0" Padding="6"
                                        Background="#42182634" BorderBrush="{StaticResource AccentBrush}"
                                        BorderThickness="1.2" CornerRadius="18">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="6" Opacity="0.5" />
                                    </Border.Effect>
                                    <ScrollViewer><ItemsPresenter /></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#EAF7FF" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemChrome" Background="{TemplateBinding Background}" CornerRadius="14"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="Transparent" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="Transparent" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource SelectedGlassBorderBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderThickness" Value="1.25" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb MinHeight="36">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Margin="2" CornerRadius="3" Background="#6670DFF2">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#46E0FF" BlurRadius="5" ShadowDepth="0" Opacity="0.25" />
                                                    </Border.Effect>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track" Width="56" Height="28" CornerRadius="14"
                                Background="#FFD1D1D6" BorderThickness="0"
                                UseLayoutRounding="True" SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="#53687C" BlurRadius="5" ShadowDepth="1" Opacity="0.18" />
                            </Border.Effect>
                            <Ellipse x:Name="Thumb" Width="24" Height="24" Margin="2"
                                     HorizontalAlignment="Left" Fill="#FFFFFFFF"
                                     UseLayoutRounding="True" SnapsToDevicePixels="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#FF34C759" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="TickFrequency" Value="1" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="34" Margin="0">
                            <Border Height="12" Margin="11,0" CornerRadius="6" VerticalAlignment="Center"
                                    Background="#42FFFFFF" BorderBrush="#A8FFFFFF" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="#547EA5" BlurRadius="8" ShadowDepth="2" Opacity="0.18" />
                                </Border.Effect>
                            </Border>
                            <Track x:Name="PART_Track" Height="28" Margin="12,0" VerticalAlignment="Center"
                                   Minimum="{TemplateBinding Minimum}" Maximum="{TemplateBinding Maximum}"
                                   Value="{TemplateBinding Value}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="10" VerticalAlignment="Center" Background="{StaticResource EnergyFillBrush}" CornerRadius="5" Margin="-1,0,-12,0">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#4D8CFF" BlurRadius="9" ShadowDepth="0" Opacity="0.42" />
                                                    </Border.Effect>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" IsTabStop="False" Background="Transparent">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton"><Border Background="Transparent" /></ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="24" Height="24">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Ellipse Stroke="#F0FFFFFF" StrokeThickness="1.4">
                                                        <Ellipse.Fill>
                                                            <RadialGradientBrush Center="0.32,0.28" GradientOrigin="0.28,0.22" RadiusX="0.74" RadiusY="0.74">
                                                                <GradientStop Color="#F0FFFFFF" Offset="0" />
                                                                <GradientStop Color="#88EAF7FF" Offset="0.30" />
                                                                <GradientStop Color="#425A9CFF" Offset="0.66" />
                                                                <GradientStop Color="#5058D78F" Offset="1" />
                                                            </RadialGradientBrush>
                                                        </Ellipse.Fill>
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect Color="#4D8CFF" BlurRadius="11" ShadowDepth="2" Opacity="0.52" />
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                    <Ellipse Width="7" Height="7" Fill="#D8FFFFFF" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,4,0,0" />
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FluentIconTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TopSectionButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="94" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Foreground" Value="{StaticResource InactiveTextBrush}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="25"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <Border.Effect>
                                    <DropShadowEffect Color="#567FA8" BlurRadius="14" ShadowDepth="4" Opacity="0.16" />
                                </Border.Effect>
                            </Border>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundSearchButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="54" />
            <Setter Property="Height" Value="54" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#294B6C" />
            <Setter Property="Background" Value="{StaticResource GlassPillBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource GlassPillBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Chrome" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="27">
                                <Border.Effect>
                                    <DropShadowEffect Color="#4E769C" BlurRadius="20" ShadowDepth="6" Opacity="0.22" />
                                </Border.Effect>
                            </Border>
                            <Border Margin="1" CornerRadius="26" BorderBrush="#D8FFFFFF" BorderThickness="1.2,1.2,0,0" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Chrome" Property="Background" Value="#B8FFFFFF" /></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Chrome" Property="Opacity" Value="0.72" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1.25" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#4776A8" BlurRadius="18" ShadowDepth="5" Opacity="0.16" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BackgroundModeButtonStyle" TargetType="Button" BasedOn="{StaticResource TopSectionButtonStyle}">
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="Height" Value="38" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Grid x:Name="ControlCenterRoot" ClipToBounds="True">
        <Image x:Name="ControlCenterBackgroundImage" Stretch="UniformToFill" Opacity="0" />
        <Rectangle Fill="{StaticResource WindowOverlayBrush}" />

        <Border x:Name="WindowGlowFrame" Margin="1" CornerRadius="17" BorderThickness="2" IsHitTestVisible="False">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <LinearGradientBrush.RelativeTransform>
                        <RotateTransform x:Name="WindowGlowRotation" CenterX="0.5" CenterY="0.5" />
                    </LinearGradientBrush.RelativeTransform>
                    <GradientStop Color="#2446E0FF" Offset="0" />
                    <GradientStop Color="#FF46E0FF" Offset="0.18" />
                    <GradientStop Color="#FF8A7DFF" Offset="0.43" />
                    <GradientStop Color="#FF4CD964" Offset="0.68" />
                    <GradientStop Color="#2446E0FF" Offset="1" />
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Effect>
                <DropShadowEffect Color="#46E0FF" BlurRadius="18" ShadowDepth="0" Opacity="0.42" />
            </Border.Effect>
            <Border.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="WindowGlowRotation"
                                             Storyboard.TargetProperty="Angle"
                                             From="0" To="360" Duration="0:0:6" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
        </Border>

        <Border Margin="3" BorderBrush="#98FFFFFF" BorderThickness="1" CornerRadius="15" Background="{StaticResource WindowSurfaceBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar" Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Margin="20,8" Background="Transparent" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,7,8,7">
                    <Button Style="{StaticResource WindowButtonStyle}" Content="—" Click="MinimizeButton_Click" />
                    <Button x:Name="MaximizeButton" Style="{StaticResource WindowButtonStyle}" Content="□" Click="MaximizeButton_Click" />
                    <Button Style="{StaticResource WindowButtonStyle}" Content="✕" Click="CloseButton_Click" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="218" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="12,0,8,12" Background="Transparent" CornerRadius="28" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1.2">
                    <Border.Effect>
                        <DropShadowEffect Color="#5279A0" BlurRadius="28" ShadowDepth="8" Opacity="0.22" />
                    </Border.Effect>
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Margin="6,10,6,18">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="34" Height="34" CornerRadius="11" Background="#84FFFFFF" BorderBrush="#A8FFFFFF" BorderThickness="1">
                                    <Border Width="23" Height="23" CornerRadius="6" Background="#404040" />
                                </Border>
                                <TextBlock Text="胶囊控制中心" FontSize="15" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Dynamic Island" FontSize="19" FontWeight="Bold" Margin="0,25,0,0" />
                            <TextBlock Text="个性化与反馈" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,5,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Row="1">
                            <Button x:Name="ThemeNavButton" Style="{StaticResource NavButtonStyle}" Tag="Theme" Click="NavigationButton_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE80F;" Style="{StaticResource FluentIconTextStyle}"/><TextBlock Text="主题" Margin="13,0,0,0" VerticalAlignment="Center"/></StackPanel></Button>
                            <Button x:Name="SettingsNavButton" Style="{StaticResource NavButtonStyle}" Tag="Settings" Click="NavigationButton_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE713;" Style="{StaticResource FluentIconTextStyle}"/><TextBlock Text="设置" Margin="13,0,0,0" VerticalAlignment="Center"/></StackPanel></Button>
                            <Button x:Name="VersionNavButton" Style="{StaticResource NavButtonStyle}" Tag="Version" Click="NavigationButton_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE946;" Style="{StaticResource FluentIconTextStyle}"/><TextBlock Text="版本信息" Margin="13,0,0,0" VerticalAlignment="Center"/></StackPanel></Button>
                            <Button x:Name="FeedbackNavButton" Style="{StaticResource NavButtonStyle}" Tag="Feedback" Click="NavigationButton_Click"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE8BD;" Style="{StaticResource FluentIconTextStyle}"/><TextBlock Text="反馈" Margin="13,0,0,0" VerticalAlignment="Center"/></StackPanel></Button>
                        </StackPanel>
                        <Button Grid.Row="2" Margin="2,8,2,8" Height="48" Foreground="#E5667C"
                                Background="Transparent" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1.2"
                                ToolTip="退出胶囊程序" Click="ExitApplicationButton_Click">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE7E8;" Style="{StaticResource FluentIconTextStyle}"/><TextBlock Text="退出程序" Margin="11,0,0,0" VerticalAlignment="Center"/></StackPanel>
                        </Button>
                        <Border Grid.Row="3" Style="{StaticResource GlassCardStyle}" CornerRadius="18" Padding="12" Margin="2,0,2,2">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="●  胶囊正在运行" Foreground="#3EBE79" FontSize="12" />
                                <TextBlock x:Name="SidebarVersionText" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="20,6,24,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="68" />
                        <RowDefinition Height="72" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="64"/></Grid.ColumnDefinitions>
                        <Border Height="64" Background="Transparent" BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1.25" CornerRadius="32" Padding="3"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect Color="#4776A8" BlurRadius="18" ShadowDepth="5" Opacity="0.16" />
                            </Border.Effect>
                            <StackPanel x:Name="TopSectionNavigationPanel" Orientation="Horizontal" />
                        </Border>
                        <Button x:Name="SearchButton" Grid.Column="1" Style="{StaticResource RoundSearchButtonStyle}" HorizontalAlignment="Right" Click="SearchButton_Click" ToolTip="搜索所有功能">
                            <TextBlock Text="&#xE721;" Style="{StaticResource FluentIconTextStyle}" FontSize="22" />
                        </Button>
                    </Grid>
                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <TextBlock x:Name="PageTitleText" Text="主题" FontSize="28" FontWeight="Bold" />
                        <TextBlock x:Name="PageSubtitleText" Text="选择胶囊的整体视觉风格" Foreground="{StaticResource MutedTextBrush}" Margin="0,5,0,0" />
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <ScrollViewer x:Name="ThemePage" VerticalScrollBarVisibility="Auto" ScrollChanged="PageScrollViewer_ScrollChanged">
                            <StackPanel Margin="0,4,10,20">
                                <TextBlock x:Name="ThemePresetsSection" Text="主题预设" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                                <UniformGrid Columns="2">
                                    <Button x:Name="ClassicThemeButton" Tag="ClassicDark" Style="{StaticResource ThemeCardStyle}" Margin="0,0,5,0" Click="ThemeButton_Click">
                                        <StackPanel>
                                            <Border x:Name="ClassicThemeCheckBadge" Width="28" Height="28" CornerRadius="14" Background="{StaticResource AccentBrush}" HorizontalAlignment="Right" Margin="0,-7,-7,-21" Panel.ZIndex="2" Visibility="Collapsed"><TextBlock Text="&#xE73E;" Style="{StaticResource FluentIconTextStyle}" Foreground="White" HorizontalAlignment="Center"/></Border>
                                            <Border Height="112" CornerRadius="14" Background="#A6183144" BorderBrush="#78D8F3FF" BorderThickness="1">
                                                <Border Height="38" Margin="18" CornerRadius="19" Background="#D8182634" BorderBrush="#8846E0FF" BorderThickness="1">
                                                    <TextBlock Text="BLUE" Foreground="#D8F3FF" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" />
                                                </Border>
                                            </Border>
                                            <TextBlock Text="Transparent Blue" FontSize="15" FontWeight="SemiBold" Margin="0,14,0,0" />
                                            <TextBlock Text="深海蓝透明玻璃与冰蓝高光" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="WhiteThemeButton" Tag="TransparentWhite" Style="{StaticResource ThemeCardStyle}" Margin="5,0,0,0" Click="ThemeButton_Click">
                                        <StackPanel>
                                            <Border x:Name="WhiteThemeCheckBadge" Width="28" Height="28" CornerRadius="14" Background="{StaticResource AccentBrush}" HorizontalAlignment="Right" Margin="0,-7,-7,-21" Panel.ZIndex="2" Visibility="Collapsed"><TextBlock Text="&#xE73E;" Style="{StaticResource FluentIconTextStyle}" Foreground="White" HorizontalAlignment="Center"/></Border>
                                            <Border Height="112" CornerRadius="14" Background="#24FFFFFF" BorderBrush="#B8FFFFFF" BorderThickness="1.2">
                                                <Border Height="38" Margin="18" CornerRadius="19" Background="#38FFFFFF" BorderBrush="#E8FFFFFF" BorderThickness="1">
                                                    <TextBlock Text="WHITE" Foreground="#F4FAFF" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" />
                                                </Border>
                                            </Border>
                                            <TextBlock Text="Transparent White" FontSize="15" FontWeight="SemiBold" Margin="0,14,0,0" />
                                            <TextBlock Text="默认透明白色液态玻璃" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Button>
                                </UniformGrid>
                                <Border x:Name="ThemePreviewSection" Style="{StaticResource GlassCardStyle}" Margin="0,22,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="300"/></Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="实时预览" FontWeight="SemiBold" FontSize="15" />
                                        <TextBlock Text="选择主题后会立即应用到正在运行的胶囊，并自动保存。" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
                                    </StackPanel>
                                        <Border Grid.Column="1" Height="46" Margin="18,0,0,0" CornerRadius="23" Background="#D4162A3E" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1.5">
                                            <Grid Margin="16,0"><TextBlock Text="胶囊实时预览" Foreground="White" VerticalAlignment="Center"/><TextBlock Text="12:54" Foreground="#CDE9FF" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                                <TextBlock Text="自定义背景" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,10" />
                                <Border x:Name="ControlCenterBackgroundSection" Style="{StaticResource GlassCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="控制中心背景" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,14" />
                                        <Border Background="Transparent" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1.2" CornerRadius="21" Padding="2" HorizontalAlignment="Left" Margin="0,0,0,16">
                                            <StackPanel Orientation="Horizontal">
                                                <Button x:Name="DefaultLandscapeModeButton" Tag="DefaultLandscape" Content="默认山水" Style="{StaticResource BackgroundModeButtonStyle}" Click="ControlCenterBackgroundModeButton_Click" />
                                                <Button x:Name="CustomImageModeButton" Tag="CustomImage" Content="自定义图片" Style="{StaticResource BackgroundModeButtonStyle}" Click="ControlCenterBackgroundModeButton_Click" />
                                                <Button x:Name="TransparentModeButton" Tag="Transparent" Content="完全透明" Style="{StaticResource BackgroundModeButtonStyle}" Click="ControlCenterBackgroundModeButton_Click" />
                                            </StackPanel>
                                        </Border>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Border Width="134" Height="76" CornerRadius="16" Background="{StaticResource LiquidGlassBrush}" BorderBrush="{StaticResource GlassPillBorderBrush}" BorderThickness="1.2">
                                                <Image x:Name="ControlCenterBackgroundImagePreview" Stretch="UniformToFill" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                                <TextBlock x:Name="ControlCenterBackgroundImageFileNameText" Text="透明玻璃（无图片）" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="只影响控制中心，不会改变胶囊背景。" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,5,0,0" />
                                                <StackPanel Orientation="Horizontal" Margin="0,11,0,0">
                                                    <Button Content="选择主页图片" Style="{StaticResource PrimaryButtonStyle}" Click="ChooseControlCenterBackgroundImageButton_Click" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                        <Separator Background="#4FFFFFFF" Margin="0,16" />
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="主页图片透明度" VerticalAlignment="Center"/>
                                            <Slider x:Name="ControlCenterBackgroundImageOpacitySlider" Grid.Column="1" ValueChanged="ControlCenterBackgroundImageOpacitySlider_ValueChanged" />
                                            <TextBlock x:Name="ControlCenterBackgroundImageOpacityValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="主页填充方式" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="ControlCenterBackgroundImageStretchComboBox" Grid.Column="1" SelectionChanged="ControlCenterBackgroundImageStretchComboBox_SelectionChanged">
                                                <ComboBoxItem Content="填充并裁剪" Tag="UniformToFill" />
                                                <ComboBoxItem Content="完整显示" Tag="Uniform" />
                                                <ComboBoxItem Content="拉伸填满" Tag="Fill" />
                                            </ComboBox>
                                        </Grid>
                                        <TextBlock x:Name="ControlCenterBackgroundImageStatusText" Foreground="#72F4A4" TextWrapping="Wrap" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="CapsuleBackgroundSection" Style="{StaticResource GlassCardStyle}" Margin="0,18,0,0">
                                    <StackPanel>
                                        <TextBlock Text="胶囊背景" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,14" />
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Border Width="134" Height="76" CornerRadius="12" Background="#111C29" BorderBrush="#355069" BorderThickness="1">
                                                <Image x:Name="BackgroundImagePreview" Stretch="UniformToFill" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                                <TextBlock x:Name="BackgroundImageFileNameText" Text="未选择图片" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="只影响胶囊本体，与控制中心背景完全独立。" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,5,0,0" />
                                                <StackPanel Orientation="Horizontal" Margin="0,11,0,0">
                                                    <Button Content="选择图片" Style="{StaticResource PrimaryButtonStyle}" Click="ChooseBackgroundImageButton_Click" />
                                                    <Button Content="移除图片" Foreground="#FF9A9A" Background="Transparent" BorderBrush="#78465353" BorderThickness="1" Padding="14,9" Margin="10,0,0,0" Cursor="Hand" Click="RemoveBackgroundImageButton_Click" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                        <Separator Background="#5AFFFFFF" Margin="0,16" />
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="图片透明度" VerticalAlignment="Center"/>
                                            <Slider x:Name="BackgroundImageOpacitySlider" Grid.Column="1" ValueChanged="BackgroundImageOpacitySlider_ValueChanged" />
                                            <TextBlock x:Name="BackgroundImageOpacityValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="填充方式" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="BackgroundImageStretchComboBox" Grid.Column="1" SelectionChanged="BackgroundImageStretchComboBox_SelectionChanged">
                                                <ComboBoxItem Content="填充并裁剪" Tag="UniformToFill" />
                                                <ComboBoxItem Content="完整显示" Tag="Uniform" />
                                                <ComboBoxItem Content="拉伸填满" Tag="Fill" />
                                            </ComboBox>
                                        </Grid>
                                        <TextBlock x:Name="BackgroundImageStatusText" Foreground="#72F4A4" TextWrapping="Wrap" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer x:Name="SettingsPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" ScrollChanged="PageScrollViewer_ScrollChanged">
                            <StackPanel Margin="0,4,10,24">
                                <TextBlock x:Name="SystemSection" Text="系统" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <Border Style="{StaticResource GlassCardStyle}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="开机自启" FontSize="14" FontWeight="SemiBold" />
                                                <TextBlock Text="登录 Windows 后自动启动胶囊软件" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,5,0,0" />
                                                <TextBlock x:Name="StartupStatusText" Foreground="#72F4A4" FontSize="11" Margin="0,7,0,0" />
                                            </StackPanel>
                                            <CheckBox x:Name="StartupCheckBox"
                                                      Grid.Column="1"
                                                      Content="启用"
                                                      Foreground="{StaticResource PrimaryTextBrush}"
                                                      VerticalAlignment="Center"
                                                      Margin="20,0,0,0"
                                                      Checked="StartupCheckBox_Changed"
                                                      Unchecked="StartupCheckBox_Changed" />
                                        </Grid>
                                        <Separator Background="{StaticResource DividerBrush}" Margin="0,16" />
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="240"/></Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="启动后显示" FontSize="14" FontWeight="SemiBold" />
                                                <TextBlock Text="选择启动软件时是否自动打开控制中心" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,5,0,0" />
                                            </StackPanel>
                                            <ComboBox x:Name="StartupDisplayModeComboBox"
                                                      Grid.Column="1"
                                                      SelectionChanged="StartupDisplayModeComboBox_SelectionChanged">
                                                <ComboBoxItem Content="胶囊和控制中心" Tag="CapsuleAndControlCenter" />
                                                <ComboBoxItem Content="仅显示胶囊" Tag="CapsuleOnly" />
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <TextBlock x:Name="AppearanceSection" Text="外观" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,10" />
                                <Border Style="{StaticResource GlassCardStyle}">
                                    <StackPanel>
                                        <Grid Margin="0,7"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="透明度" VerticalAlignment="Center"/><Slider x:Name="GlassOpacitySlider" Grid.Column="1" Tag="GlassOpacity" ValueChanged="SettingSlider_ValueChanged"/><TextBlock x:Name="GlassOpacityValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                        <Grid Margin="0,7"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="阴影" VerticalAlignment="Center"/><Slider x:Name="ShadowSlider" Grid.Column="1" Tag="Shadow" ValueChanged="SettingSlider_ValueChanged"/><TextBlock x:Name="ShadowValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                        <Grid Margin="0,7"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="胶囊粗细" VerticalAlignment="Center"/><Slider x:Name="CapsuleThicknessSlider" Grid.Column="1" Tag="CapsuleThickness" ValueChanged="SettingSlider_ValueChanged"/><TextBlock x:Name="CapsuleThicknessValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                        <Grid Margin="0,7"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="胶囊长度" VerticalAlignment="Center"/><Slider x:Name="CapsuleLengthSlider" Grid.Column="1" Tag="CapsuleLength" ValueChanged="SettingSlider_ValueChanged"/><TextBlock x:Name="CapsuleLengthValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                        <Grid Margin="0,7"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="中心卡片宽度" VerticalAlignment="Center"/><Slider x:Name="CenterCardWidthSlider" Grid.Column="1" Tag="CenterCardWidth" ValueChanged="SettingSlider_ValueChanged"/><TextBlock x:Name="CenterCardWidthValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                    </StackPanel>
                                </Border>

                                <TextBlock x:Name="GlowSection" Text="流光" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,10" />
                                <Border Style="{StaticResource GlassCardStyle}">
                                    <StackPanel>
                                        <Grid Margin="0,7"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="亮度" VerticalAlignment="Center"/><Slider x:Name="GlowIntensitySlider" Grid.Column="1" Tag="GlowIntensity" ValueChanged="SettingSlider_ValueChanged"/><TextBlock x:Name="GlowIntensityValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                        <Grid Margin="0,7"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="粗细" VerticalAlignment="Center"/><Slider x:Name="GlowThicknessSlider" Grid.Column="1" Tag="GlowThickness" ValueChanged="SettingSlider_ValueChanged"/><TextBlock x:Name="GlowThicknessValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                        <Grid Margin="0,7"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="速度" VerticalAlignment="Center"/><Slider x:Name="GlowSpeedSlider" Grid.Column="1" Tag="GlowSpeed" ValueChanged="SettingSlider_ValueChanged"/><TextBlock x:Name="GlowSpeedValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                    </StackPanel>
                                </Border>

                                <TextBlock x:Name="LyricsSection" Text="歌词语言" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,10" />
                                <Border Style="{StaticResource GlassCardStyle}">
                                    <ComboBox x:Name="LyricLanguageComboBox" Width="220" HorizontalAlignment="Left" SelectionChanged="LyricLanguageComboBox_SelectionChanged">
                                        <ComboBoxItem Content="简体中文" Tag="Simplified" />
                                        <ComboBoxItem Content="繁體中文" Tag="Traditional" />
                                    </ComboBox>
                                </Border>

                                <TextBlock x:Name="PresentationSection" Text="功能区域" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,10" />
                                <Border Style="{StaticResource GlassCardStyle}">
                                    <StackPanel x:Name="PresentationSettingsPanel" />
                                </Border>

                                <TextBlock x:Name="ConfigurationSection" Text="配置管理" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,10" />
                                <Border Style="{StaticResource GlassCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="备份或迁移当前主题、布局、应用和功能区域设置。导入前会验证文件，恢复默认不会改变开机自启注册状态。"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                            <Button Content="导出配置" Style="{StaticResource PrimaryButtonStyle}" Click="ExportConfigurationButton_Click" />
                                            <Button Content="导入配置" Style="{StaticResource PrimaryButtonStyle}" Margin="10,0,0,0" Click="ImportConfigurationButton_Click" />
                                            <Button Content="恢复默认"
                                                    Foreground="#FF9A9A"
                                                    Background="Transparent"
                                                    BorderBrush="#78465353"
                                                    BorderThickness="1"
                                                    Padding="18,10"
                                                    Margin="10,0,0,0"
                                                    Cursor="Hand"
                                                    Click="ResetConfigurationButton_Click" />
                                        </StackPanel>
                                        <TextBlock x:Name="ConfigurationStatusText" Foreground="#72F4A4" TextWrapping="Wrap" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer x:Name="VersionPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" ScrollChanged="PageScrollViewer_ScrollChanged">
                            <StackPanel Margin="0,4,10,20">
                                <Border x:Name="VersionInfoSection" Style="{StaticResource GlassCardStyle}" Padding="26">
                                    <StackPanel>
                                        <Border Width="76" Height="76" CornerRadius="24" Background="#1C3447" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" HorizontalAlignment="Left">
                                            <TextBlock Text="◆" Foreground="{StaticResource AccentBrush}" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock x:Name="ProductNameText" FontSize="24" FontWeight="Bold" Margin="0,18,0,0" />
                                        <TextBlock x:Name="ProductVersionText" Foreground="{StaticResource AccentBrush}" FontSize="14" Margin="0,7,0,0" />
                                        <Separator Background="#5AFFFFFF" Margin="0,22" />
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions><RowDefinition Height="36"/><RowDefinition Height="36"/><RowDefinition Height="36"/></Grid.RowDefinitions>
                                            <TextBlock Text=".NET 运行时" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/><TextBlock x:Name="RuntimeText" Grid.Column="1" VerticalAlignment="Center"/>
                                            <TextBlock Text="操作系统" Grid.Row="1" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/><TextBlock x:Name="OperatingSystemText" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                            <TextBlock Text="程序架构" Grid.Row="2" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/><TextBlock x:Name="ArchitectureText" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Button Content="复制版本信息" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Margin="0,22,0,0" Click="CopyVersionButton_Click" />
                                        <TextBlock x:Name="CopyVersionStatusText" Foreground="#72F4A4" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border x:Name="DiagnosticsSection" Style="{StaticResource GlassCardStyle}" Padding="22" Margin="0,18,0,0">
                                    <StackPanel>
                                        <TextBlock Text="诊断中心" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Text="诊断内容不包含歌词、歌曲名、应用列表、用户文件路径或反馈附件。"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,7,0,0" />
                                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                            <Button Content="复制诊断信息" Style="{StaticResource PrimaryButtonStyle}" Click="CopyDiagnosticsButton_Click" />
                                            <Button Content="打开日志目录" Style="{StaticResource PrimaryButtonStyle}" Margin="10,0,0,0" Click="OpenLogDirectoryButton_Click" />
                                            <Button Content="清理日志"
                                                    Foreground="#FF9A9A"
                                                    Background="Transparent"
                                                    BorderBrush="#78465353"
                                                    BorderThickness="1"
                                                    Padding="18,10"
                                                    Margin="10,0,0,0"
                                                    Cursor="Hand"
                                                    Click="ClearDiagnosticsButton_Click" />
                                        </StackPanel>
                                        <TextBlock x:Name="DiagnosticsStatusText" Foreground="#72F4A4" TextWrapping="Wrap" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer x:Name="FeedbackPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" ScrollChanged="PageScrollViewer_ScrollChanged">
                            <StackPanel Margin="0,4,10,24">
                                <Border x:Name="FeedbackTextSection" Style="{StaticResource GlassCardStyle}" Padding="22">
                                    <StackPanel>
                                        <TextBlock Text="告诉我们你遇到的问题或希望增加的功能" FontSize="15" FontWeight="SemiBold" />
                                        <TextBox x:Name="FeedbackTextBox" Height="190" Margin="0,14,0,0" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top" TextChanged="FeedbackTextBox_TextChanged" />
                                        <TextBlock x:Name="FeedbackCountText" Text="0 字" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Right" Margin="0,6,0,0" />

                                        <Border x:Name="FeedbackDropZone" Margin="0,18,0,0" Padding="18" CornerRadius="12" Background="Transparent" BorderThickness="0" AllowDrop="True" DragOver="FeedbackDropZone_DragOver" Drop="FeedbackDropZone_Drop">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="添加图片附件" FontWeight="SemiBold" />
                                                    <TextBlock Text="拖入或选择 PNG、JPG、WebP、BMP；最多 5 张，每张不超过 10MB" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,5,0,0" />
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="选择图片" Style="{StaticResource PrimaryButtonStyle}" Click="SelectFeedbackImagesButton_Click" />
                                            </Grid>
                                        </Border>

                                        <StackPanel x:Name="FeedbackAttachmentsPanel" Margin="0,12,0,0" />
                                        <TextBlock x:Name="FeedbackStatusText" Foreground="#FFB66E" TextWrapping="Wrap" Margin="0,10,0,0" />
                                        <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                            <Button Content="提交反馈" Style="{StaticResource PrimaryButtonStyle}" IsEnabled="False" ToolTip="等待配置开发者邮箱和服务器" />
                                            <TextBlock Text="反馈渠道尚未配置，当前内容不会上传。" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="14,0,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
        </Border>

        <Popup x:Name="FeatureSearchPopup" PlacementTarget="{Binding ElementName=SearchButton}"
               Placement="Bottom" HorizontalOffset="-330" VerticalOffset="8"
               AllowsTransparency="True" StaysOpen="False" PopupAnimation="Fade">
            <Border Width="390" MaxHeight="430" Padding="16" CornerRadius="26"
                    Background="Transparent"
                    BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1.2">
                <Border.Effect>
                    <DropShadowEffect Color="#355B82" BlurRadius="30" ShadowDepth="8" Opacity="0.25" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="搜索控制中心" FontSize="17" FontWeight="Bold"
                               Foreground="{StaticResource FeatureSearchForegroundBrush}" />
                    <Grid Height="44" Margin="0,12,0,10">
                        <TextBox x:Name="FeatureSearchTextBox" Style="{StaticResource FeatureSearchTextBoxStyle}"
                                 TextChanged="FeatureSearchTextBox_TextChanged" KeyDown="FeatureSearchTextBox_KeyDown" />
                        <Button Content="&#xE721;" Style="{StaticResource FeatureSearchButtonStyle}"
                                HorizontalAlignment="Right" Margin="0,0,6,0" Click="FeatureSearchSubmitButton_Click" />
                    </Grid>
                    <ListBox x:Name="FeatureSearchResultsList" MaxHeight="310" Background="Transparent"
                             BorderThickness="0" MouseLeftButtonUp="FeatureSearchResultsList_MouseLeftButtonUp"
                             KeyDown="FeatureSearchResultsList_KeyDown"
                             ItemContainerStyle="{StaticResource FeatureSearchResultItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" Margin="0,2" CornerRadius="12" Background="Transparent">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource FeatureSearchForegroundBrush}" />
                                        <TextBlock Text="{Binding Location}" Foreground="{StaticResource FeatureSearchMutedBrush}" FontSize="11" Margin="0,3,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock x:Name="FeatureSearchEmptyText" Text="没有找到匹配功能" Visibility="Collapsed"
                               Foreground="{StaticResource FeatureSearchMutedBrush}" HorizontalAlignment="Center" Margin="0,18" />
                    <TextBlock Text="Enter 定位 · Esc 关闭" Foreground="{StaticResource FeatureSearchMutedBrush}" FontSize="10" HorizontalAlignment="Right" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>

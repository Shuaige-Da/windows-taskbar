<Window x:Class="DynamicIslandBar.CapsuleControlCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="胶囊控制中心"
        Width="1120" Height="760"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="#00000000"
        Foreground="#F4F8FF"
        ShowInTaskbar="True"
        SizeChanged="ControlCenterWindow_SizeChanged">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="7"
                            CornerRadius="16"
                            GlassFrameThickness="0" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#D8E6F0" />
        <SolidColorBrush x:Key="AccentBrush" Color="#46E0FF" />
        <SolidColorBrush x:Key="AccentSecondaryBrush" Color="#4CD964" />
        <SolidColorBrush x:Key="WindowSurfaceBrush" Color="#18FFFFFF" />
        <SolidColorBrush x:Key="WindowOverlayBrush" Color="#0CFFFFFF" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#24FFFFFF" />
        <SolidColorBrush x:Key="CardBrush" Color="#2EFFFFFF" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#86FFFFFF" />

        <LinearGradientBrush x:Key="EnergyFillBrush" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Color="#FF1DB8FF" Offset="0" />
            <GradientStop Color="#FF46E0FF" Offset="0.5" />
            <GradientStop Color="#FF4CD964" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="LiquidGlassBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#68FFFFFF" Offset="0" />
            <GradientStop Color="#26FFFFFF" Offset="0.52" />
            <GradientStop Color="#42E7F7FF" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#EAF7FF" />
            <Setter Property="Background" Value="{StaticResource LiquidGlassBrush}" />
            <Setter Property="BorderBrush" Value="#5A6E91A9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#A846E0FF" />
                                <Setter TargetName="Chrome" Property="Background" Value="#AA1B3346" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.34" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="WindowButtonStyle">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Foreground" Value="#DDE8F7" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#26364A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="NavButtonStyle">
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="#C8D4E4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11">
                            <Grid>
                                <Border Width="3" Margin="5,10,0,10" CornerRadius="2"
                                        HorizontalAlignment="Left" Background="{TemplateBinding BorderBrush}" />
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#18283A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryButtonStyle">
            <Setter Property="Foreground" Value="#06131B" />
            <Setter Property="Background" Value="{StaticResource EnergyFillBrush}" />
            <Setter Property="BorderBrush" Value="#805CF2FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect Color="#46E0FF" BlurRadius="12" ShadowDepth="0" Opacity="0.22" />
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.86" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="ThemeCardStyle">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="5" Opacity="0.28" />
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#D31B2A3B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#EFF7FF" />
            <Setter Property="Background" Value="#34FFFFFF" />
            <Setter Property="BorderBrush" Value="#86FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="#46E0FF" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#EFF7FF" />
            <Setter Property="Background" Value="#38FFFFFF" />
            <Setter Property="BorderBrush" Value="#86FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press" Foreground="{TemplateBinding Foreground}"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboChrome" Background="#38FFFFFF"
                                                BorderBrush="#86FFFFFF" BorderThickness="1" CornerRadius="10">
                                            <Grid>
                                                <ContentPresenter Margin="12,8" HorizontalAlignment="Left" VerticalAlignment="Center" />
                                                <Border Width="3" Height="14" Margin="0,0,12,0" CornerRadius="2"
                                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                                        Background="{StaticResource AccentBrush}" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboChrome" Property="BorderBrush" Value="#B846E0FF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" />
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" IsOpen="{TemplateBinding IsDropDownOpen}" PopupAnimation="Fade">
                                <Border MinWidth="240" MaxHeight="260" Margin="0,5,0,0" Padding="5"
                                        Background="#E8525C68" BorderBrush="#A8FFFFFF"
                                        BorderThickness="1" CornerRadius="10">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="6" Opacity="0.5" />
                                    </Border.Effect>
                                    <ScrollViewer><ItemsPresenter /></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#EAF7FF" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemChrome" Background="{TemplateBinding Background}" CornerRadius="7">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#5A24455A" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#70306A70" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb MinHeight="36">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Margin="2" CornerRadius="3" Background="#6670DFF2">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#46E0FF" BlurRadius="5" ShadowDepth="0" Opacity="0.25" />
                                                    </Border.Effect>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track" Width="56" Height="30" CornerRadius="15"
                                Background="#38FFFFFF" BorderBrush="#86FFFFFF" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="#46E0FF" BlurRadius="9" ShadowDepth="0" Opacity="0.28" />
                            </Border.Effect>
                            <Ellipse x:Name="Thumb" Width="24" Height="24" Margin="3"
                                     HorizontalAlignment="Left" Fill="#F4FAFF" Stroke="#90FFFFFF" StrokeThickness="1">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="7" ShadowDepth="1" Opacity="0.38" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource EnergyFillBrush}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="#A572F4A4" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="#B8BFEFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="TickFrequency" Value="1" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="28" Margin="3,0">
                            <Border Height="12" CornerRadius="6" VerticalAlignment="Center"
                                    Background="#28FFFFFF" BorderBrush="#72FFFFFF" BorderThickness="1" />
                            <Track x:Name="PART_Track" Height="10" Margin="1,0" VerticalAlignment="Center"
                                   Minimum="{TemplateBinding Minimum}" Maximum="{TemplateBinding Maximum}"
                                   Value="{TemplateBinding Value}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{StaticResource EnergyFillBrush}" CornerRadius="5">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#46E0FF" BlurRadius="9" ShadowDepth="0" Opacity="0.58" />
                                                    </Border.Effect>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" IsTabStop="False" Background="Transparent">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton"><Border Background="Transparent" /></ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="15" Height="20">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Margin="-3,0,0,0" CornerRadius="8"
                                                        Background="{StaticResource EnergyFillBrush}"
                                                        BorderBrush="#D8FFFFFF" BorderThickness="1">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#46E0FF" BlurRadius="10" ShadowDepth="0" Opacity="0.75" />
                                                    </Border.Effect>
                                                    <Ellipse Width="5" Height="5" Fill="#F5FFFFFF"
                                                             HorizontalAlignment="Right" Margin="0,0,3,0" />
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="ControlCenterRoot" ClipToBounds="True">
        <Image x:Name="ControlCenterBackgroundImage" Stretch="UniformToFill" Opacity="0" />
        <Rectangle Fill="{StaticResource WindowOverlayBrush}" />

        <Border x:Name="WindowGlowFrame" Margin="1" CornerRadius="17" BorderThickness="2" IsHitTestVisible="False">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <LinearGradientBrush.RelativeTransform>
                        <RotateTransform x:Name="WindowGlowRotation" CenterX="0.5" CenterY="0.5" />
                    </LinearGradientBrush.RelativeTransform>
                    <GradientStop Color="#2446E0FF" Offset="0" />
                    <GradientStop Color="#FF46E0FF" Offset="0.18" />
                    <GradientStop Color="#FF8A7DFF" Offset="0.43" />
                    <GradientStop Color="#FF4CD964" Offset="0.68" />
                    <GradientStop Color="#2446E0FF" Offset="1" />
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Effect>
                <DropShadowEffect Color="#46E0FF" BlurRadius="18" ShadowDepth="0" Opacity="0.42" />
            </Border.Effect>
            <Border.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="WindowGlowRotation"
                                             Storyboard.TargetProperty="Angle"
                                             From="0" To="360" Duration="0:0:6" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
        </Border>

        <Border Margin="3" BorderBrush="#98FFFFFF" BorderThickness="1" CornerRadius="15" Background="{StaticResource WindowSurfaceBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar" Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <Border Width="30" Height="30" CornerRadius="10" Background="#50324A5E" BorderBrush="#8246E0FF" BorderThickness="1">
                        <Image Source="pack://application:,,,/DynamicIslandBar;component/Assets/DynamicIslandBar-AppIcon.png"
                               Width="20" Height="20" Stretch="Uniform" />
                    </Border>
                    <TextBlock Text="胶囊控制中心" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,7,8,7">
                    <Button Style="{StaticResource WindowButtonStyle}" Content="—" Click="MinimizeButton_Click" />
                    <Button x:Name="MaximizeButton" Style="{StaticResource WindowButtonStyle}" Content="□" Click="MaximizeButton_Click" />
                    <Button Style="{StaticResource WindowButtonStyle}" Content="✕" Click="CloseButton_Click" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="218" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="12,0,8,12" Background="{StaticResource SidebarBrush}" CornerRadius="20" BorderBrush="#7EFFFFFF" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="22" ShadowDepth="5" Opacity="0.28" />
                    </Border.Effect>
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Margin="6,12,6,18">
                            <TextBlock Text="Dynamic Island" FontSize="19" FontWeight="Bold" />
                            <TextBlock Text="个性化与反馈" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,5,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Row="1">
                            <Button x:Name="ThemeNavButton" Style="{StaticResource NavButtonStyle}" Tag="Theme" Click="NavigationButton_Click" Content="主题" />
                            <Button x:Name="SettingsNavButton" Style="{StaticResource NavButtonStyle}" Tag="Settings" Click="NavigationButton_Click" Content="设置" />
                            <Button x:Name="VersionNavButton" Style="{StaticResource NavButtonStyle}" Tag="Version" Click="NavigationButton_Click" Content="版本信息" />
                            <Button x:Name="FeedbackNavButton" Style="{StaticResource NavButtonStyle}" Tag="Feedback" Click="NavigationButton_Click" Content="反馈" />
                        </StackPanel>
                        <Border Grid.Row="2" Background="#2EFFFFFF" BorderBrush="#72FFFFFF"
                                BorderThickness="1" CornerRadius="14" Padding="12" Margin="2,8,2,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="胶囊正在运行" Foreground="#72F4A4" FontSize="12" />
                                    <TextBlock x:Name="SidebarVersionText" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,4,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1" Content="退出" Padding="11,7" Margin="8,0,0,0"
                                        Foreground="#FFFFE8E8" BorderBrush="#9AFFFFFF"
                                        ToolTip="退出胶囊程序" Click="ExitApplicationButton_Click" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="20,6,24,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="72" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="PageTitleText" Text="主题" FontSize="28" FontWeight="Bold" />
                        <TextBlock x:Name="PageSubtitleText" Text="选择胶囊的整体视觉风格" Foreground="{StaticResource MutedTextBrush}" Margin="0,5,0,0" />
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <ScrollViewer x:Name="ThemePage" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,4,10,20">
                                <TextBlock Text="主题预设" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                                <UniformGrid Columns="3">
                                    <Button x:Name="ClassicThemeButton" Tag="ClassicDark" Style="{StaticResource ThemeCardStyle}" Margin="0,0,10,0" Click="ThemeButton_Click">
                                        <StackPanel>
                                            <Border Height="112" CornerRadius="14" Background="#A6183144" BorderBrush="#78D8F3FF" BorderThickness="1">
                                                <Border Height="38" Margin="18" CornerRadius="19" Background="#D8182634" BorderBrush="#8846E0FF" BorderThickness="1">
                                                    <TextBlock Text="CLASSIC" Foreground="#D8F3FF" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" />
                                                </Border>
                                            </Border>
                                            <TextBlock Text="Classic Dark" Foreground="White" FontSize="15" FontWeight="SemiBold" Margin="0,14,0,0" />
                                            <TextBlock Text="深海蓝玻璃与冰蓝边缘" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="GreenThemeButton" Tag="GlassGreen" Style="{StaticResource ThemeCardStyle}" Margin="5,0" Click="ThemeButton_Click">
                                        <StackPanel>
                                            <Border Height="112" CornerRadius="14" Background="#B814302A" BorderBrush="#554CD964" BorderThickness="1">
                                                <Border Height="38" Margin="18" CornerRadius="19" Background="#D317211E" BorderBrush="#884CD964" BorderThickness="1">
                                                    <TextBlock Text="GLASS" Foreground="#72F4A4" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" />
                                                </Border>
                                            </Border>
                                            <TextBlock Text="Glass Green" Foreground="White" FontSize="15" FontWeight="SemiBold" Margin="0,14,0,0" />
                                            <TextBlock Text="墨绿玻璃与荧光绿强调" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="LightThemeButton" Tag="SoftLight" Style="{StaticResource ThemeCardStyle}" Margin="10,0,0,0" Click="ThemeButton_Click">
                                        <StackPanel>
                                            <Border Height="112" CornerRadius="14" Background="#E6F2F2F2" BorderBrush="#551F8A70" BorderThickness="1">
                                                <Border Height="38" Margin="18" CornerRadius="19" Background="#F5FFFFFF" BorderBrush="#661F8A70" BorderThickness="1">
                                                    <TextBlock Text="SOFT" Foreground="#1F8A70" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" />
                                                </Border>
                                            </Border>
                                            <TextBlock Text="Soft Light" Foreground="White" FontSize="15" FontWeight="SemiBold" Margin="0,14,0,0" />
                                            <TextBlock Text="柔和浅色与青绿点缀" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Button>
                                </UniformGrid>
                                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="18" Margin="0,22,0,0">
                                    <StackPanel>
                                        <TextBlock Text="实时预览" FontWeight="SemiBold" FontSize="15" />
                                        <TextBlock Text="选择主题后会立即应用到正在运行的胶囊，并自动保存。" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="自定义背景" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,10" />
                                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="控制中心背景" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,14" />
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Border Width="134" Height="76" CornerRadius="16" Background="#24FFFFFF" BorderBrush="#86FFFFFF" BorderThickness="1">
                                                <Image x:Name="ControlCenterBackgroundImagePreview" Stretch="UniformToFill" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                                <TextBlock x:Name="ControlCenterBackgroundImageFileNameText" Text="透明玻璃（无图片）" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="只影响主页；移除图片后恢复透明的 iOS 液体玻璃。" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,5,0,0" />
                                                <StackPanel Orientation="Horizontal" Margin="0,11,0,0">
                                                    <Button Content="选择主页图片" Style="{StaticResource PrimaryButtonStyle}" Click="ChooseControlCenterBackgroundImageButton_Click" />
                                                    <Button Content="恢复透明" Foreground="#FFFFE8E8" Background="#24FFFFFF" BorderBrush="#86FFFFFF" BorderThickness="1" Padding="14,9" Margin="10,0,0,0" Cursor="Hand" Click="RemoveControlCenterBackgroundImageButton_Click" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                        <Separator Background="#4FFFFFFF" Margin="0,16" />
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="主页图片透明度" VerticalAlignment="Center"/>
                                            <Slider x:Name="ControlCenterBackgroundImageOpacitySlider" Grid.Column="1" ValueChanged="ControlCenterBackgroundImageOpacitySlider_ValueChanged" />
                                            <TextBlock x:Name="ControlCenterBackgroundImageOpacityValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="主页填充方式" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="ControlCenterBackgroundImageStretchComboBox" Grid.Column="1" SelectionChanged="ControlCenterBackgroundImageStretchComboBox_SelectionChanged">
                                                <ComboBoxItem Content="填充并裁剪" Tag="UniformToFill" />
                                                <ComboBoxItem Content="完整显示" Tag="Uniform" />
                                                <ComboBoxItem Content="拉伸填满" Tag="Fill" />
                                            </ComboBox>
                                        </Grid>
                                        <TextBlock x:Name="ControlCenterBackgroundImageStatusText" Foreground="#72F4A4" TextWrapping="Wrap" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="18" Margin="0,14,0,0">
                                    <StackPanel>
                                        <TextBlock Text="胶囊背景" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,14" />
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Border Width="134" Height="76" CornerRadius="12" Background="#111C29" BorderBrush="#355069" BorderThickness="1">
                                                <Image x:Name="BackgroundImagePreview" Stretch="UniformToFill" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                                <TextBlock x:Name="BackgroundImageFileNameText" Text="未选择图片" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="只影响胶囊本体，与控制中心背景完全独立。" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,5,0,0" />
                                                <StackPanel Orientation="Horizontal" Margin="0,11,0,0">
                                                    <Button Content="选择图片" Style="{StaticResource PrimaryButtonStyle}" Click="ChooseBackgroundImageButton_Click" />
                                                    <Button Content="移除图片" Foreground="#FF9A9A" Background="Transparent" BorderBrush="#78465353" BorderThickness="1" Padding="14,9" Margin="10,0,0,0" Cursor="Hand" Click="RemoveBackgroundImageButton_Click" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                        <Separator Background="#294056" Margin="0,16" />
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="图片透明度" VerticalAlignment="Center"/>
                                            <Slider x:Name="BackgroundImageOpacitySlider" Grid.Column="1" ValueChanged="BackgroundImageOpacitySlider_ValueChanged" />
                                            <TextBlock x:Name="BackgroundImageOpacityValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="填充方式" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="BackgroundImageStretchComboBox" Grid.Column="1" SelectionChanged="BackgroundImageStretchComboBox_SelectionChanged">
                                                <ComboBoxItem Content="填充并裁剪" Tag="UniformToFill" />
                                                <ComboBoxItem Content="完整显示" Tag="Uniform" />
                                                <ComboBoxItem Content="拉伸填满" Tag="Fill" />
                                            </ComboBox>
                                        </Grid>
                                        <TextBlock x:Name="BackgroundImageStatusText" Foreground="#72F4A4" TextWrapping="Wrap" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer x:Name="SettingsPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,4,10,24">
                                <TextBlock Text="系统" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="18">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="开机自启" FontSize="14" FontWeight="SemiBold" />
                                                <TextBlock Text="登录 Windows 后自动启动胶囊软件" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,5,0,0" />
                                                <TextBlock x:Name="StartupStatusText" Foreground="#72F4A4" FontSize="11" Margin="0,7,0,0" />
                                            </StackPanel>
                                            <CheckBox x:Name="StartupCheckBox"
                                                      Grid.Column="1"
                                                      Content="启用"
                                                      Foreground="White"
                                                      VerticalAlignment="Center"
                                                      Margin="20,0,0,0"
                                                      Checked="StartupCheckBox_Changed"
                                                      Unchecked="StartupCheckBox_Changed" />
                                        </Grid>
                                        <Separator Background="#294056" Margin="0,16" />
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="240"/></Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="启动后显示" FontSize="14" FontWeight="SemiBold" />
                                                <TextBlock Text="选择启动软件时是否自动打开控制中心" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,5,0,0" />
                                            </StackPanel>
                                            <ComboBox x:Name="StartupDisplayModeComboBox"
                                                      Grid.Column="1"
                                                      SelectionChanged="StartupDisplayModeComboBox_SelectionChanged">
                                                <ComboBoxItem Content="胶囊和控制中心" Tag="CapsuleAndControlCenter" />
                                                <ComboBoxItem Content="仅显示胶囊" Tag="CapsuleOnly" />
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="外观" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,10" />
                                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="18">
                                    <StackPanel>
                                        <Grid Margin="0,7"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="透明度" VerticalAlignment="Center"/><Slider x:Name="GlassOpacitySlider" Grid.Column="1" Tag="GlassOpacity" ValueChanged="SettingSlider_ValueChanged"/><TextBlock x:Name="GlassOpacityValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                        <Grid Margin="0,7"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="阴影" VerticalAlignment="Center"/><Slider x:Name="ShadowSlider" Grid.Column="1" Tag="Shadow" ValueChanged="SettingSlider_ValueChanged"/><TextBlock x:Name="ShadowValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                        <Grid Margin="0,7"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="胶囊粗细" VerticalAlignment="Center"/><Slider x:Name="CapsuleThicknessSlider" Grid.Column="1" Tag="CapsuleThickness" ValueChanged="SettingSlider_ValueChanged"/><TextBlock x:Name="CapsuleThicknessValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                        <Grid Margin="0,7"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="胶囊长度" VerticalAlignment="Center"/><Slider x:Name="CapsuleLengthSlider" Grid.Column="1" Tag="CapsuleLength" ValueChanged="SettingSlider_ValueChanged"/><TextBlock x:Name="CapsuleLengthValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                        <Grid Margin="0,7"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="中心卡片宽度" VerticalAlignment="Center"/><Slider x:Name="CenterCardWidthSlider" Grid.Column="1" Tag="CenterCardWidth" ValueChanged="SettingSlider_ValueChanged"/><TextBlock x:Name="CenterCardWidthValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="流光" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,10" />
                                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="18">
                                    <StackPanel>
                                        <Grid Margin="0,7"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="亮度" VerticalAlignment="Center"/><Slider x:Name="GlowIntensitySlider" Grid.Column="1" Tag="GlowIntensity" ValueChanged="SettingSlider_ValueChanged"/><TextBlock x:Name="GlowIntensityValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                        <Grid Margin="0,7"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="粗细" VerticalAlignment="Center"/><Slider x:Name="GlowThicknessSlider" Grid.Column="1" Tag="GlowThickness" ValueChanged="SettingSlider_ValueChanged"/><TextBlock x:Name="GlowThicknessValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                        <Grid Margin="0,7"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="52"/></Grid.ColumnDefinitions><TextBlock Text="速度" VerticalAlignment="Center"/><Slider x:Name="GlowSpeedSlider" Grid.Column="1" Tag="GlowSpeed" ValueChanged="SettingSlider_ValueChanged"/><TextBlock x:Name="GlowSpeedValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="歌词语言" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,10" />
                                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="18">
                                    <ComboBox x:Name="LyricLanguageComboBox" Width="220" HorizontalAlignment="Left" SelectionChanged="LyricLanguageComboBox_SelectionChanged">
                                        <ComboBoxItem Content="简体中文" Tag="Simplified" />
                                        <ComboBoxItem Content="繁體中文" Tag="Traditional" />
                                    </ComboBox>
                                </Border>

                                <TextBlock Text="功能区域" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,10" />
                                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="18">
                                    <StackPanel x:Name="PresentationSettingsPanel" />
                                </Border>

                                <TextBlock Text="配置管理" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,10" />
                                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="备份或迁移当前主题、布局、应用和功能区域设置。导入前会验证文件，恢复默认不会改变开机自启注册状态。"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                            <Button Content="导出配置" Style="{StaticResource PrimaryButtonStyle}" Click="ExportConfigurationButton_Click" />
                                            <Button Content="导入配置" Style="{StaticResource PrimaryButtonStyle}" Margin="10,0,0,0" Click="ImportConfigurationButton_Click" />
                                            <Button Content="恢复默认"
                                                    Foreground="#FF9A9A"
                                                    Background="Transparent"
                                                    BorderBrush="#78465353"
                                                    BorderThickness="1"
                                                    Padding="18,10"
                                                    Margin="10,0,0,0"
                                                    Cursor="Hand"
                                                    Click="ResetConfigurationButton_Click" />
                                        </StackPanel>
                                        <TextBlock x:Name="ConfigurationStatusText" Foreground="#72F4A4" TextWrapping="Wrap" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer x:Name="VersionPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,4,10,20">
                                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="26">
                                    <StackPanel>
                                        <Border Width="76" Height="76" CornerRadius="24" Background="#1C3447" BorderBrush="#7246E0FF" BorderThickness="1" HorizontalAlignment="Left">
                                            <TextBlock Text="◆" Foreground="#46E0FF" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock x:Name="ProductNameText" FontSize="24" FontWeight="Bold" Margin="0,18,0,0" />
                                        <TextBlock x:Name="ProductVersionText" Foreground="#46E0FF" FontSize="14" Margin="0,7,0,0" />
                                        <Separator Background="#294056" Margin="0,22" />
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions><RowDefinition Height="36"/><RowDefinition Height="36"/><RowDefinition Height="36"/></Grid.RowDefinitions>
                                            <TextBlock Text=".NET 运行时" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/><TextBlock x:Name="RuntimeText" Grid.Column="1" VerticalAlignment="Center"/>
                                            <TextBlock Text="操作系统" Grid.Row="1" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/><TextBlock x:Name="OperatingSystemText" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                            <TextBlock Text="程序架构" Grid.Row="2" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/><TextBlock x:Name="ArchitectureText" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Button Content="复制版本信息" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left" Margin="0,22,0,0" Click="CopyVersionButton_Click" />
                                        <TextBlock x:Name="CopyVersionStatusText" Foreground="#72F4A4" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="22" Margin="0,18,0,0">
                                    <StackPanel>
                                        <TextBlock Text="诊断中心" FontSize="16" FontWeight="SemiBold" />
                                        <TextBlock Text="诊断内容不包含歌词、歌曲名、应用列表、用户文件路径或反馈附件。"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,7,0,0" />
                                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                            <Button Content="复制诊断信息" Style="{StaticResource PrimaryButtonStyle}" Click="CopyDiagnosticsButton_Click" />
                                            <Button Content="打开日志目录" Style="{StaticResource PrimaryButtonStyle}" Margin="10,0,0,0" Click="OpenLogDirectoryButton_Click" />
                                            <Button Content="清理日志"
                                                    Foreground="#FF9A9A"
                                                    Background="Transparent"
                                                    BorderBrush="#78465353"
                                                    BorderThickness="1"
                                                    Padding="18,10"
                                                    Margin="10,0,0,0"
                                                    Cursor="Hand"
                                                    Click="ClearDiagnosticsButton_Click" />
                                        </StackPanel>
                                        <TextBlock x:Name="DiagnosticsStatusText" Foreground="#72F4A4" TextWrapping="Wrap" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer x:Name="FeedbackPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,4,10,24">
                                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="22">
                                    <StackPanel>
                                        <TextBlock Text="告诉我们你遇到的问题或希望增加的功能" FontSize="15" FontWeight="SemiBold" />
                                        <TextBox x:Name="FeedbackTextBox" Height="190" Margin="0,14,0,0" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top" TextChanged="FeedbackTextBox_TextChanged" />
                                        <TextBlock x:Name="FeedbackCountText" Text="0 字" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Right" Margin="0,6,0,0" />

                                        <Border x:Name="FeedbackDropZone" Margin="0,18,0,0" Padding="18" CornerRadius="12" Background="#71101B28" BorderBrush="#3D5C76" BorderThickness="1" AllowDrop="True" DragOver="FeedbackDropZone_DragOver" Drop="FeedbackDropZone_Drop">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="添加图片附件" FontWeight="SemiBold" />
                                                    <TextBlock Text="拖入或选择 PNG、JPG、WebP、BMP；最多 5 张，每张不超过 10MB" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,5,0,0" />
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="选择图片" Style="{StaticResource PrimaryButtonStyle}" Click="SelectFeedbackImagesButton_Click" />
                                            </Grid>
                                        </Border>

                                        <StackPanel x:Name="FeedbackAttachmentsPanel" Margin="0,12,0,0" />
                                        <TextBlock x:Name="FeedbackStatusText" Foreground="#FFB66E" TextWrapping="Wrap" Margin="0,10,0,0" />
                                        <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                            <Button Content="提交反馈" Style="{StaticResource PrimaryButtonStyle}" IsEnabled="False" ToolTip="等待配置开发者邮箱和服务器" />
                                            <TextBlock Text="反馈渠道尚未配置，当前内容不会上传。" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="14,0,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
        </Border>
    </Grid>
</Window>

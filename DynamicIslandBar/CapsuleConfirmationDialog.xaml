<Window x:Class="DynamicIslandBar.CapsuleConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="430" Height="230"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="DialogPillButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface" CornerRadius="20" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DialogCloseButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface" CornerRadius="16" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#24FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Border x:Name="DialogSurface" CornerRadius="28" BorderThickness="1.4" Padding="22">
            <Border.Effect>
                <DropShadowEffect x:Name="DialogShadow" BlurRadius="34" ShadowDepth="8" Opacity="0.58" Color="#B0000000" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="DialogIconSurface" Width="34" Height="34" CornerRadius="17" BorderThickness="1">
                            <TextBlock x:Name="DialogIconGlyph" Text="&#xE7E8;" FontFamily="Segoe Fluent Icons" FontSize="15"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock x:Name="DialogTitleText" Margin="12,0,0,0" FontSize="17" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Button x:Name="CloseButton" Content="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="12"
                            Width="32" Height="32" HorizontalAlignment="Right" Cursor="Hand"
                            Background="Transparent" BorderThickness="0" Style="{StaticResource DialogCloseButtonStyle}"
                            Click="CancelButton_Click" />
                </Grid>

                <TextBlock x:Name="DialogMessageText" Grid.Row="1" Margin="46,18,8,18" FontSize="14"
                           TextWrapping="Wrap" VerticalAlignment="Center" />

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton" Content="取消" MinWidth="96" Height="40" Margin="0,0,10,0"
                            Cursor="Hand" BorderThickness="1" Style="{StaticResource DialogPillButtonStyle}"
                            IsCancel="True"
                            Click="CancelButton_Click" />
                    <Button x:Name="ConfirmButton" Content="退出程序" MinWidth="112" Height="40"
                            Cursor="Hand" BorderThickness="1" Style="{StaticResource DialogPillButtonStyle}"
                            IsDefault="True"
                            Click="ConfirmButton_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
